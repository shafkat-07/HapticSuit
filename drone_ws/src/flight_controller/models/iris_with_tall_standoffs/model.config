<?xml version="1.0"?>
<model>
  <name>Iris with Tall Standoffs</name>
  <version>1.0</version>
  <sdf version="1.5">model.sdf</sdf>

  <author>
    <name>HapticSuit</name>
    <email>hapticsuit@example.com</email>
  </author>

  <description>
    Fork of iris_with_standoffs with taller landing gear (base_link at 0.5 m
    instead of 0.195 m).  The extra height provides ground clearance for a
    suspended payload on a rigid tether.  Collision-enabled foot spheres
    replace the original visual-only legs as the ground-contact geometry.
  </description>
</model>

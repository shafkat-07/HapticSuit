<?xml version="1.0"?>
<model>
  <name>Iris with ArduPilot and Suspended Payload</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>HapticSuit</name>
    <email>hapticsuit@example.com</email>
  </author>

  <description>
    Fork of iris_with_ardupilot that adds a suspended payload on a rigid
    tether via a ball joint.  The payload link, tether visual, and joint
    live inside the same model tree as the drone so the physics engine
    treats them as intra-model constraints (much more stable than
    world-level joints between separate models).
  </description>

  <depend>
    <model>
      <uri>model://gimbal_small_2d</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://iris_with_standoffs</uri>
      <version>1.0</version>
    </model>
  </depend>
</model>

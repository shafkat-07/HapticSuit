<?xml version="1.0"?>
<model>
  <name>Drone Intruder</name>
  <version>1.0</version>
  <sdf version='1.6'>model.sdf</sdf>
  <author>
    <name>HapticSuit</name>
    <email>hapticsuit@example.com</email>
  </author>
  <description>
    Visual-only quadcopter model used as the flyover intruder in the
    downwash simulation scenario.  Gravity is disabled so the model
    floats wherever it is placed by /gazebo/set_model_state.
  </description>
</model>
